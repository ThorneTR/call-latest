{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "testMatch": ["**/jest.test.ts"],
  "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
  "extensionsToTreatAsEsm": [".ts"],
  "globals": {
    "ts-jest": {
      "useESM": true,
      "tsconfig": {
        "module": "esnext",
        "target": "ES2020",
        "lib": ["ES2020"],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "moduleResolution": "node"
      }
    }
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
